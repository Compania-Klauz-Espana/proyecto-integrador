{
  "title": "Proyecto Integrador — System Health",
  "uid": "pi-system-health",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["kubernetes", "spring-boot", "klauz"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_pod_info, namespace)",
        "current": { "value": "klauz-dev" },
        "includeAll": false
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Pods Running",
      "type": "stat", "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "datasource": "Prometheus",
      "targets": [{"expr":"count(kube_pod_status_phase{namespace=\"$namespace\",phase=\"Running\"})","legendFormat":"Running"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color":"red","value":0},{"color":"yellow","value":1},{"color":"green","value":2}]},"color":{"mode":"thresholds"}}}
    },
    {
      "id": 2, "title": "CPU Usage por Pod",
      "type": "timeseries", "gridPos": {"x":4,"y":0,"w":10,"h":8},
      "datasource": "Prometheus",
      "targets": [{"expr":"sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\",container!=\"\"}[5m])) by (pod) * 100","legendFormat":"{{pod}}"}],
      "fieldConfig": {"defaults": {"unit":"percent","thresholds": {"steps":[{"color":"green","value":0},{"color":"yellow","value":60},{"color":"red","value":80}]}}}
    },
    {
      "id": 3, "title": "Memory Usage por Pod",
      "type": "timeseries", "gridPos": {"x":14,"y":0,"w":10,"h":8},
      "datasource": "Prometheus",
      "targets": [{"expr":"sum(container_memory_working_set_bytes{namespace=\"$namespace\",container!=\"\"}) by (pod) / 1024 / 1024","legendFormat":"{{pod}}"}],
      "fieldConfig": {"defaults": {"unit":"MiB"}}
    },
    {
      "id": 4, "title": "HTTP Request Rate (req/s)",
      "type": "timeseries", "gridPos": {"x":0,"y":8,"w":12,"h":7},
      "datasource": "Prometheus",
      "targets": [{"expr":"sum(rate(http_server_requests_seconds_count{namespace=\"$namespace\"}[1m])) by (uri, method)","legendFormat":"{{method}} {{uri}}"}],
      "fieldConfig": {"defaults": {"unit":"reqps"}}
    },
    {
      "id": 5, "title": "Error Rate 5xx (%)",
      "type": "timeseries", "gridPos": {"x":12,"y":8,"w":12,"h":7},
      "datasource": "Prometheus",
      "targets": [{"expr":"sum(rate(http_server_requests_seconds_count{namespace=\"$namespace\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{namespace=\"$namespace\"}[1m])) * 100","legendFormat":"Error Rate"}],
      "fieldConfig": {"defaults": {"unit":"percent","thresholds": {"steps":[{"color":"green","value":0},{"color":"yellow","value":1},{"color":"red","value":5}]}}}
    },
    {
      "id": 6, "title": "Latencia p95",
      "type": "timeseries", "gridPos": {"x":0,"y":15,"w":12,"h":7},
      "datasource": "Prometheus",
      "targets": [{"expr":"histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{namespace=\"$namespace\"}[5m])) by (le, uri))","legendFormat":"p95 {{uri}}"}],
      "fieldConfig": {"defaults": {"unit":"s"}}
    },
    {
      "id": 7, "title": "JVM Heap Used vs Max",
      "type": "timeseries", "gridPos": {"x":12,"y":15,"w":12,"h":7},
      "datasource": "Prometheus",
      "targets": [
        {"expr":"jvm_memory_used_bytes{namespace=\"$namespace\",area=\"heap\"} / 1024 / 1024","legendFormat":"Used {{id}}"},
        {"expr":"jvm_memory_max_bytes{namespace=\"$namespace\",area=\"heap\"} / 1024 / 1024","legendFormat":"Max {{id}}"}
      ],
      "fieldConfig": {"defaults": {"unit":"MiB"}}
    },
    {
      "id": 8, "title": "Pod Restarts (24h)",
      "type": "stat", "gridPos": {"x":0,"y":22,"w":4,"h":4},
      "datasource": "Prometheus",
      "targets": [{"expr":"sum(increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[24h])) by (pod)","legendFormat":"{{pod}}"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps":[{"color":"green","value":0},{"color":"yellow","value":3},{"color":"red","value":10}]}}}
    },
    {
      "id": 9, "title": "Application Logs (Loki)",
      "type": "logs", "gridPos": {"x":0,"y":26,"w":24,"h":10},
      "datasource": "Loki",
      "targets": [{"expr":"{namespace=\"$namespace\", app=~\"backend|frontend\"}","legendFormat":""}],
      "options": {"showTime":true,"showLabels":true,"wrapLogMessage":true,"sortOrder":"Descending"}
    },
    {
      "id": 10, "title": "Log Volume por Nivel",
      "type": "timeseries", "gridPos": {"x":0,"y":36,"w":24,"h":6},
      "datasource": "Loki",
      "targets": [
        {"expr":"sum(rate({namespace=\"$namespace\"} |= `INFO` [1m]))","legendFormat":"INFO"},
        {"expr":"sum(rate({namespace=\"$namespace\"} |= `WARN` [1m]))","legendFormat":"WARN"},
        {"expr":"sum(rate({namespace=\"$namespace\"} |= `ERROR` [1m]))","legendFormat":"ERROR"}
      ]
    }
  ]
}
